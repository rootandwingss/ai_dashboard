# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://olympiad:olympiad_secret@localhost:5432/olympiad_db

# ─── Mock Mode (run without Docker) ──────────────────────
MOCK_MODE=true

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── MinIO / S3 ─────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=olympiad-uploads
MINIO_USE_SSL=false

# ─── Vision Engine ──────────────────────────────────────
VISION_ENGINE_URL=http://localhost:8000

# ─── Google Cloud Vision OCR ────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./path-to-your-service-account.json

# ─── Orchestrator ───────────────────────────────────────
ORCHESTRATOR_PORT=4000

# ─── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
